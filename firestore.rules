rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Validates the shape of a Patient document
    function isValidPatient(data) {
      return data.id is string 
        && data.id.size() <= 128 
        && data.demographics is map 
        && data.demographics.name is string 
        && data.demographics.name.size() <= 200
        && data.diagnosis is string 
        && data.diagnosis.size() <= 2000 
        && data.status is string 
        && data.status.size() <= 200;
    }

    // Rules for patients collection
    match /patients/{patientId} {
      allow read, list, get: if isSignedIn();
      
      allow create: if isSignedIn() 
        && isValidId(patientId) 
        && isValidPatient(incoming())
        && incoming().id == patientId;
        
      allow update: if isSignedIn() 
        && isValidId(patientId) 
        && isValidPatient(incoming())
        && incoming().id == existing().id;
        
      allow delete: if isSignedIn();
    }
  }
}
